# ──────────────────────────────────────────────────────────────
# Easy MTA — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────

# MTA Developer API Key
# Obtain a free key at: https://api.mta.info/#/signup
# Leave blank to run in demo mode with mock data.
MTA_API_KEY=

# Dify API settings
# Self-hosted Dify: e.g. http://localhost  (the app appends /v1/chat-messages)
# Dify Cloud:       https://api.dify.ai
# Leave blank to run in demo mode.
DIFY_API_URL=https://api.dify.ai
DIFY_API_KEY=
